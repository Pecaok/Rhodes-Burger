# Config NO sensible de la función de facturación.
# Copiá este archivo como `.env` (mismo directorio) antes de deployar.
# Los datos sensibles (CUIT, certificado, clave) van como SECRETS, no acá:
#   firebase functions:secrets:set AFIP_CUIT
#   firebase functions:secrets:set AFIP_CERT
#   firebase functions:secrets:set AFIP_KEY

# true = facturas reales; vacío o false = homologación (pruebas)
AFIP_PRODUCTION=false
# Punto de venta habilitado en ARCA para web services
AFIP_PUNTO_VENTA=1
